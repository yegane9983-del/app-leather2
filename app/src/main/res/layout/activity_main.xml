<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="محاسبه‌گر مصرف چرم"
            android:textColor="#3E2723"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="افزودن محصول"
            android:textColor="#5D4037"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/productNameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="نام محصول؛ مثال: دلار"
            android:inputType="text"
            android:singleLine="true"
            android:textDirection="rtl"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/defaultUsageEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="مصرف پیش‌فرض به پا؛ مثال: ۴"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:textDirection="rtl" />

        <Button
            android:id="@+id/addProductButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ذخیره محصول"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="لیست محصولات"
            android:textColor="#5D4037"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="برای حذف محصول، روی آن چند لحظه نگه دارید."
            android:textColor="#666666"
            android:textSize="13sp"
            android:paddingTop="4dp" />

        <ListView
            android:id="@+id/productsListView"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginTop="8dp"
            android:background="#FFFFFF"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="محاسبه مابه‌التفاوت"
            android:textColor="#5D4037"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ماه محاسبه"
            android:textColor="#616161"
            android:textSize="14sp"
            android:layout_marginTop="10dp" />

        <Spinner
            android:id="@+id/monthSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <AutoCompleteTextView
            android:id="@+id/productSearchEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:completionThreshold="1"
            android:hint="جستجو و انتخاب محصول"
            android:inputType="text"
            android:singleLine="true"
            android:textDirection="rtl" />

        <EditText
            android:id="@+id/quantityEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="تعداد محصول"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:textDirection="rtl"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/actualLeatherEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="چرم مصرفی واقعی به پا"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:textDirection="rtl" />

        <Button
            android:id="@+id/calculateButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="محاسبه و ذخیره"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/recordsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="مشاهده سوابق مابه‌التفاوت ماهانه"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/resultTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="نتیجه اینجا نمایش داده می‌شود."
            android:textColor="#212121"
            android:textSize="17sp"
            android:lineSpacingExtra="5dp"
            android:padding="14dp"
            android:layout_marginTop="14dp"
            android:background="#FFFFFF" />

    </LinearLayout>
</ScrollView>
