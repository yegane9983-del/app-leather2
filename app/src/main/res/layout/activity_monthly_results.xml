<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:padding="18dp"
    android:textDirection="rtl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="سوابق مابه‌التفاوت ماهانه"
        android:textColor="#3E2723"
        android:textSize="22sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="انتخاب ماه برای نمایش سوابق"
        android:textColor="#5D4037"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/filterMonthSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/monthlyTotalTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#EFEBE9"
        android:gravity="center"
        android:padding="14dp"
        android:text="جمع مابه‌التفاوت: ۰ پا"
        android:textColor="#3E2723"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/emptyTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:padding="18dp"
        android:text="در این ماه سابقه‌ای ثبت نشده است."
        android:textColor="#616161"
        android:textSize="16sp" />

    <ListView
        android:id="@+id/recordsListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:text="برای حذف یک سابقه، روی آن چند لحظه نگه دارید."
        android:textColor="#666666"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/clearRecordsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="حذف همه سوابق" />

        <Button
            android:id="@+id/backButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="بازگشت" />
    </LinearLayout>

</LinearLayout>
